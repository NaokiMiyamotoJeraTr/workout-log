{
  "name": "workout-log",
  "version": "1.0.0",
  "description": "シンプルかつ使い勝手の良い、筋トレ記録アプリです。前回記録を簡単に参照でき、徐々に筋トレの強度を上げられる。種目も自分でカスタマイズ可能！",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "db:migrate": "knex migrate:latest",
    "db:migrate-make": "knex migrate:make",
    "db:seed": "knex seed:run",
    "db:seed-make": "knex seed:make",
    "db:reset": "knex migrate:rollback --all && knex migrate:latest && knex seed:run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NaokiMiyamotoJeraTr/workout-log.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/NaokiMiyamotoJeraTr/workout-log/issues"
  },
  "homepage": "https://github.com/NaokiMiyamotoJeraTr/workout-log#readme",
  "dependencies": {
    "dotenv": "^17.3.1",
    "knex": "^3.1.0",
    "pg": "^8.18.0"
  }
}
